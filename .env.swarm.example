# ============================================
# Docker Swarm - Baileys API Deployment
# ============================================

# 🔑 Secrets (use valores seguros em produção)
INTERNAL_API_KEY=seu-internal-api-key-super-secreto-min-32-chars
JWT_ACCESS_SECRET=seu-jwt-access-secret-super-secreto
JWT_REFRESH_SECRET=seu-jwt-refresh-secret-super-secreto

# 🌐 Domain
DOMAIN=zap-api.wesenderbrasil.com.br

# 📊 Database
POSTGRES_DB=wa_saas
POSTGRES_USER=wa_user
POSTGRES_PASSWORD=sua-senha-postgres-super-segura

# 💾 Redis
REDIS_PASSWORD=sua-senha-redis-opcional

# 🚀 API
HTTP_PORT=8080
ENGINE_PORT=8090
