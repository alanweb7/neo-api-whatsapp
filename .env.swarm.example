# ============================================
# Docker Swarm - Baileys API Deployment
# ============================================

# 🔑 Secrets (use valores seguros em produção)
# Mínimo 32 caracteres para INTERNAL_API_KEY
INTERNAL_API_KEY=changeme123456789012345678901234
JWT_ACCESS_SECRET=changeme123456789012345678901234
JWT_REFRESH_SECRET=changeme123456789012345678901234

# 🌐 Domain
DOMAIN=zap-api.wesenderbrasil.com.br
ENGINE_DOMAIN=engine.zap-api.wesenderbrasil.com.br

# 📊 Database - PostgreSQL
POSTGRES_DB=wa_saas
POSTGRES_USER=wa_user
POSTGRES_PASSWORD=changeme123456789012345
DATABASE_URL=postgres://wa_user:changeme123456789012345@postgres:5432/wa_saas?sslmode=disable

# 💾 Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# 🚀 Application
APP_ENV=production
APP_NAME=baileys-saas-core
HTTP_PORT=8080
ENGINE_PORT=8090
NODE_ENV=production

# ⏱️ JWT Configuration
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30

# 🔗 Engine Communication
ENGINE_BASE_URL=http://whatsapp-engine:8090
WA_EVENTS_CHANNEL=wa.events.v1
SESSION_STORE_PATH=/app/data/sessions

# 📦 Resource Limits
POSTGRES_MAX_CONNECTIONS=200
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
